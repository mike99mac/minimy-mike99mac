#!/bin/bash
#
# should be run from minimy base dir
# Example:
#     install/installminimy
#
#+--------------------------------------------------------------------------+
function usage
# Give help to the user
#+--------------------------------------------------------------------------+
 {
  : SOURCE: ${BASH_SOURCE}
  : STACK:  ${FUNCNAME[@]}

  echo "Name: installminimy - Install the Minimy voice assistant"
  echo "Usage: installminimy [OPTIONS]"
  echo ""
  echo "OPTIONS:"
  echo "  -h|--help           Give help (this screen)"
  echo "  -H|--hub [HUB]      Specify the 'hub' server"
  echo "  -v|--verbose        Verbose output"
  echo "  -x|--debug          Print commands and arguments as they are executed"
  exit 51
 }                                         # usage()

#+--------------------------------------------------------------------------+
function parseArgs
# Parse arguments
# Args: All arguments passed into script
#+--------------------------------------------------------------------------+
 {
  : SOURCE: ${BASH_SOURCE}
  : STACK:  ${FUNCNAME[@]}

  while [ -n "$1" ]                        # loop through args passed in
  do
    case "$1" in
      -h|--help)
        usage
        ;;
      -H|--hub)
        if [ $# = 0 ]; then                # hostname not passed in
          echo "ERROR! HUB not passed in after $1"
          usage                            # give help
        fi
        shift                              # get to next arg
        hub=$1
        ;;
      -v|--verbose)
        verbose=2
        ;;
      -x|--debug)                          # turn trace on
         set -vx
         ;;
      *)
        echo "ERROR: Too many arguments: $1"
        usage
        ;;
    esac
    shift                                  # move to next arg
  done
 }                                         # parseArgs()

#+--------------------------------------------------------------------------+
function getPlatform
# Set platform to either "Raspberry Pi" or "NVIDIA Jetson" else warn
#+--------------------------------------------------------------------------+
 {
  : SOURCE: ${BASH_SOURCE}
  : STACK:  ${FUNCNAME[@]}

  platform=`cat /proc/device-tree/model | awk '{print $1 " " $2}'`
  if [ "$platform" != "Raspberry Pi" -a "$platform" != "NVIDIA Jetson" ]; then
    echo "WARNING: Only Nvidia Jetson and Raspberry Pi platforms are supported."
  fi
 }                                         # getPlatform()

#+--------------------------------------------------------------------------+
function detectUserInfo
# Detect the current user, UID, and base directory
#+--------------------------------------------------------------------------+
 {
  : SOURCE: ${BASH_SOURCE}
  : STACK:  ${FUNCNAME[@]}

  # Detect current user information
  CURRENT_USER=$(whoami)
  CURRENT_UID=$(id -u)
  CURRENT_GROUP=$(id -gn)

  echo "Detected user: $CURRENT_USER (UID: $CURRENT_UID, Group: $CURRENT_GROUP)" | tee -a $logFile
  echo "Base directory: $baseDir" | tee -a $logFile

  # Validate that we're not running as root
  if [ "$CURRENT_USER" = "root" ]; then
    echo "ERROR: Do not run this script as root. Run as a regular user with sudo privileges."
    exit 5
  fi

  # Check if base directory exists
  if [ ! -d "$baseDir" ]; then
    echo "ERROR: Base directory $baseDir not found"
    exit 2
  fi
 }                                         # detectUserInfo()

#+--------------------------------------------------------------------------+
function generateServiceFiles
# Generate systemd service files from templates with dynamic user and paths
#+--------------------------------------------------------------------------+
 {
  : SOURCE: ${BASH_SOURCE}
  : STACK:  ${FUNCNAME[@]}

  echo | tee -a $logFile
  echo "Generating systemd service files from templates..." | tee -a $logFile

  # Create a temporary directory for generated files
  local tmpDir=$(mktemp -d)

  # Generate minimy.service from template
  if [ ! -f "$baseDir/install/minimy.service.template" ]; then
    echo "ERROR: minimy.service.template not found" | tee -a $logFile
    exit 6
  fi
  sed -e "s|{{USER}}|$CURRENT_USER|g" \
      -e "s|{{GROUP}}|$CURRENT_GROUP|g" \
      -e "s|{{BASE_DIR}}|$baseDir|g" \
      -e "s|{{UID}}|$CURRENT_UID|g" \
      "$baseDir/install/minimy.service.template" > "$tmpDir/minimy.service"
  echo "Generated minimy.service" | tee -a $logFile

  # Generate whisper.service from template
  if [ ! -f "$baseDir/install/whisper.service.template" ]; then
    echo "ERROR: whisper.service.template not found" | tee -a $logFile
    exit 7
  fi
  sed -e "s|{{USER}}|$CURRENT_USER|g" \
      -e "s|{{GROUP}}|$CURRENT_GROUP|g" \
      -e "s|{{BASE_DIR}}|$baseDir|g" \
      -e "s|{{UID}}|$CURRENT_UID|g" \
      "$baseDir/install/whisper.service.template" > "$tmpDir/whisper.service"
  echo "Generated whisper.service" | tee -a $logFile

  # Generate mount unit name based on base directory path
  # systemd mount units must be named after the mount path with - replacing /
  local mountUnitPath=$(echo "$baseDir" | sed 's|^/||; s|/|-|g')

  # Generate logs mount file from template
  if [ ! -f "$baseDir/install/minimy-logs.mount.template" ]; then
    echo "ERROR: minimy-logs.mount.template not found" | tee -a $logFile
    exit 8
  fi
  sed -e "s|{{USER}}|$CURRENT_USER|g" \
      -e "s|{{GROUP}}|$CURRENT_GROUP|g" \
      -e "s|{{BASE_DIR}}|$baseDir|g" \
      "$baseDir/install/minimy-logs.mount.template" > "$tmpDir/${mountUnitPath}-logs.mount"
  echo "Generated ${mountUnitPath}-logs.mount" | tee -a $logFile

  # Generate tmp mount file from template
  if [ ! -f "$baseDir/install/minimy-tmp.mount.template" ]; then
    echo "ERROR: minimy-tmp.mount.template not found" | tee -a $logFile
    exit 9
  fi
  sed -e "s|{{USER}}|$CURRENT_USER|g" \
      -e "s|{{GROUP}}|$CURRENT_GROUP|g" \
      -e "s|{{BASE_DIR}}|$baseDir|g" \
      "$baseDir/install/minimy-tmp.mount.template" > "$tmpDir/${mountUnitPath}-tmp.mount"
  echo "Generated ${mountUnitPath}-tmp.mount" | tee -a $logFile

  # Store the mount unit names for later use
  LOGS_MOUNT_UNIT="${mountUnitPath}-logs.mount"
  TMP_MOUNT_UNIT="${mountUnitPath}-tmp.mount"

  # Copy generated files to /etc/systemd/system
  echo "Installing systemd service files..." | tee -a $logFile
  runCmd sudo cp "$tmpDir/minimy.service" /etc/systemd/system/minimy.service
  runCmd sudo cp "$tmpDir/whisper.service" /etc/systemd/system/whisper.service
  runCmd sudo cp "$tmpDir/${mountUnitPath}-logs.mount" "/etc/systemd/system/${mountUnitPath}-logs.mount"
  runCmd sudo cp "$tmpDir/${mountUnitPath}-tmp.mount" "/etc/systemd/system/${mountUnitPath}-tmp.mount"

  rm -rf "$tmpDir"                         # cleanup temporary directory
  runCmd sudo systemctl daemon-reload      # reload systemd to pick up new files
  runCmd sudo systemctl start whisper      # start whisper for this session
  echo "Systemd service files installed successfully" | tee -a $logFile
 }                                         # generateServiceFiles()

#+--------------------------------------------------------------------------+
function generateConfigFile
# Generate mmconfig.yml from template with dynamic base directory
#+--------------------------------------------------------------------------+
 {
  : SOURCE: ${BASH_SOURCE}
  : STACK:  ${FUNCNAME[@]}

  echo | tee -a $logFile
  echo "Generating configuration file..." | tee -a $logFile

  if [ -f "$baseDir/install/mmconfig.yml.template" ]; then
    sed -e "s|{{BASE_DIR}}|$baseDir|g" \
        -e "s|{{USER}}|$CURRENT_USER|g" \
        -e "s|{{GROUP}}|$CURRENT_GROUP|g" \
        "$baseDir/install/mmconfig.yml.template" > "$baseDir/install/mmconfig.yml"
    echo "Generated mmconfig.yml with BaseDir: $baseDir" | tee -a $logFile
  elif [ -f "$baseDir/install/mmconfig.yml" ]; then
    # Update existing config file - use generic pattern to match any path
    # This handles /home/pi/minimy, /home/username/minimy, /opt/minimy, etc.
    sed -i "s|BaseDir: .*/minimy|BaseDir: $baseDir|g" "$baseDir/install/mmconfig.yml"
    # Also handle cases where BaseDir might have a different structure
    sed -i "s|BaseDir: /[^[:space:]]*|BaseDir: $baseDir|g" "$baseDir/install/mmconfig.yml"
    echo "Updated existing mmconfig.yml with BaseDir: $baseDir" | tee -a $logFile
  else
    echo "WARNING: No config template or file found" | tee -a $logFile
  fi
 }                                         # generateConfigFile()

#+--------------------------------------------------------------------------+
function setMinimyVars
# Set Minimy variables in mmconfig.yaml:
# - hub: host name of server doing STT and Q&A
# - musicDir: directory with music files
#+--------------------------------------------------------------------------+
 {
  : SOURCE: ${BASH_SOURCE}
  : STACK:  ${FUNCNAME[@]}

  if [ ${#hub} = 0 ]; then                 # hub not set with args
    hub=`grep "    Hub:" $configFile | awk '{print $2}'` # get hub in config file
    echo -n "Host name of hub server [$hub]: "
    read hub
  fi
  if [ ${#hub} != 0 ]; then                # new value was supplied
    sed -i "s/    Hub: .*/    Hub: $hub/g" $configFile # reset hub server
  fi
 }                                         # setMinimyVars()

#+--------------------------------------------------------------------------+
function runCmd
# run a command, report time spent and exit if it fails
#+--------------------------------------------------------------------------+
 {
  : SOURCE: ${BASH_SOURCE}
  : STACK:  ${FUNCNAME[@]}

  cmd="$@"                                 # get all args
  let stepNum=$stepNum+1
  echo | tee -a $logFile
  echo "Step $stepNum: $cmd ..." 2>&1 | tee -a $logFile # show the command and send to output file
  eval $cmd >> $logFile 2>&1               # run command and log output
  rc=$?
  if [ "$rc" != 0 ]; then                  # it failed
    echo "ERROR: $cmd returned $rc" | tee -a $logFile
    echo "Log file: $logFile"
    exit 1
  else
    echo "rc = 0"
  fi
  let curSecs=$SECONDS
  let et=$curSecs-$lastSecs
  echo "Step $stepNum took $et seconds" | tee -a $logFile
  lastSecs=$curSecs
 }                                         # runCmd()

#+--------------------------------------------------------------------------+
function checkEnv
# Check that the base directory exists and create config if needed
#+--------------------------------------------------------------------------+
 {
  : SOURCE: ${BASH_SOURCE}
  : STACK:  ${FUNCNAME[@]}

  if [ ! -d $baseDir ]; then
    echo "ERROR: base directory $baseDir not found"
    exit 2
  fi

  # Generate config file from template if it doesn't exist
  if [ ! -f $configFile ]; then
    if [ -f "$baseDir/install/mmconfig.yml.template" ]; then
      echo "Config file not found, generating from template..."
      sed -e "s|{{BASE_DIR}}|$baseDir|g" \
          -e "s|{{USER}}|$(whoami)|g" \
          "$baseDir/install/mmconfig.yml.template" > "$configFile"
    else
      echo "ERROR: Minimy config file $configFile not found and no template available"
      exit 3
    fi
  fi
 }                                         # checkEnv()

#+--------------------------------------------------------------------------+
function buildVenv
# Build the virtual environment
#+--------------------------------------------------------------------------+
 {
  : SOURCE: ${BASH_SOURCE}
  : STACK:  ${FUNCNAME[@]}

  echo
  echo "Running $0 at `date` ..." > $logFile # create a new log file
  echo | tee -a $logFile

  # Export environment variables needed by Python scripts
  export SVA_BASE_DIR="$baseDir"
  export PYTHONPATH="$baseDir"
  echo "Set SVA_BASE_DIR=$baseDir" | tee -a $logFile
  echo "Set PYTHONPATH=$baseDir" | tee -a $logFile

  echo "cd to $baseDir ..." | tee -a $logFile
  cd $baseDir
  echo | tee -a $logFile
  if command -v apt-get &>/dev/null; then
    runCmd sudo apt-get install -y python3-venv python3-dev
  fi
  PI_MODEL=$(grep -q "Raspberry Pi 4" /proc/device-tree/model 2>/dev/null && echo "4" || echo "other")
  if [ "$PI_MODEL" = "4" ]; then # Select Python version
    PYTHON=python3.11
    echo "Python 3.11 not found. Compiling for Pi 4..."
    runCmd sudo apt update
    runCmd sudo apt install -y build-essential wget libssl-dev zlib1g-dev libncurses5-dev \
    libncursesw5-dev libreadline-dev libsqlite3-dev libffi-dev libbz2-dev
    if [ ! -f Python-3.11.9.tgz ]; then
      runCmd wget https://www.python.org/ftp/python/3.11.9/Python-3.11.9.tgz
    fi
    runCmd tar xf Python-3.11.9.tgz
    cd Python-3.11.9
    runCmd ./configure --enable-optimizations
    runCmd make -j$(nproc)
    runCmd sudo make altinstall
    cd $baseDir
    echo "Installing virtual environment ..." | tee -a $logFile
    runCmd python3.11 -m venv minimy_venv
  else                                     # assume Ras Pi 5
    PYTHON=python3
    runCmd python3 -m venv minimy_venv
  fi
  echo | tee -a $logFile
  echo "Upgrading pip ..." | tee -a $logFile
  local pipCmd="$baseDir/minimy_venv/bin/pip" # use pip from the venv
  runCmd $pipCmd install --upgrade pip
  runCmd $baseDir/minimy_venv/bin/$PYTHON -m pip install --force-reinstall https://github.com/yt-dlp/yt-dlp/archive/master.tar.gz
  echo | tee -a $logFile
  echo "Activating virtual environment ..." | tee -a $logFile
  runCmd source minimy_venv/bin/activate   # start virtual environment
  echo | tee -a $logFile
  echo "Upgrading wheel and setuptools ..." | tee -a $logFile
  runCmd $pipCmd install --upgrade wheel setuptools
  if command -v apt-get &>/dev/null; then
    runCmd sudo apt-get install -y build-essential portaudio19-dev mpg123 ffmpeg curl wget mpc \
      libavutil-dev libswscale-dev libswresample-dev libavfilter-dev libavcodec-dev libavformat-dev \
      libavdevice-dev redis
  fi
  echo | tee -a $logFile
  local pythonVer=`python -V | awk '{print $2}' | awk -F'.' '{print $1"."$2}'`
  echo "Python version: $pythonVer ..." | tee -a $logFile
  local pythonCmd="$baseDir/minimy_venv/bin/python$pythonVer" # use python from the venv
  if [ "$platform" = "NVIDIA Jetson" ] && [ ! -d "$baseDir/CTranslate2" ]; then
    echo "Building CTranslate2 from source ..."
    cd $baseDir
    runCmd git clone --recurse-submodules https://github.com/OpenNMT/CTranslate2
    cd CTranslate2
    mkdir build; cd build
    runCmd sudo apt-get install -y libomp-dev
    runCmd cmake .. -DWITH_CUDA=ON -DWITH_CUDNN=ON -DWITH_MKL=OFF -DWITH_RUY=ON
    runCmd make -j6
    runCmd sudo make install
    cd ../python
    runCmd $pipCmd install -r install_requirements.txt
    runCmd python setup.py bdist_wheel
    runCmd $pipCmd install --force-reinstall dist/*.whl
  fi
  runCmd $pythonCmd -m pip install --force-reinstall https://github.com/yt-dlp/yt-dlp/archive/master.tar.gz
  echo "Installing yt-dlp and requirements.txt ..." | tee -a $logFile
  cd $baseDir
  runCmd $pipCmd install --no-binary :all: regex # force pip to ignore old wheels and build fresh
  echo "Installing python3-lingua-franca ..." | tee -a $logFile
  runCmd $pipCmd install lingua_franca
  runCmd $pipCmd install psutil
  runCmd $pipCmd install -r install/requirements.txt
  echo "Installing local STT faster-whisper" | tee -a $logFile
  runCmd $pipCmd install faster-whisper
  runCmd $pipCmd install datasets
  runCmd $pipCmd install gpiozero
  runCmd $pipCmd install keyboard
  if command -v apt-get &>/dev/null; then
    runCmd sudo apt-get install -y swig liblgpio-dev
  fi
  if [ $(uname -m) = "aarch64" ]; then
    runCmd $pipCmd install lgpio           # Only builds on ARM
  fi
  runCmd $pipCmd install quart
  runCmd $pipCmd install redis
  runCmd $pipCmd install whisper
  runCmd $pipCmd install youtube-search
  runCmd $pipCmd install git+https://github.com/wiseman/py-webrtcvad.git

  echo | tee -a $logFile
  echo "Installing local ytplay/ytadd in /usr/local/sbin ..." | tee -a $logFile
  runCmd sudo cp install/ytplay /usr/local/sbin
  if [ ! -f /usr/local/sbin/ytadd ]; then
    runCmd sudo ln -s /usr/local/sbin/ytplay /usr/local/sbin/ytadd
  fi
  runCmd $pipCmd install youtube-search-python
  echo | tee -a $logFile
  cd $baseDir/framework/services/intent/nlp/local

  echo "Building CMU link grammar ..." | tee -a $logFile
  runCmd tar xzf cmu_link-4.1b.tar.gz
  echo | tee -a $logFile
  echo "cd to link-4.1b ..." | tee -a $logFile
  cd link-4.1b
  runCmd make

  echo "Installing Local STT ..." | tee -a $logFile
  echo | tee -a $logFile
  cd $baseDir/install
  echo "Loading the whisper model"
  if [ "$pythonVer" = "3.11" ]; then
    echo "Downgrading numpy to 1.24" | tee -a $logFile
    runCmd $pipCmd install --force-reinstall numpy==1.24 # numpy must be 1.24 for building whisper
    pip list | grep numpy                  # show the new version
  fi
  runCmd $pythonCmd $baseDir/bldwhisper.py $baseDir/jfk.wav # build the whisper model specified in mmconfig.yml
  if [ "$pythonVer" = "3.11" ]; then
    echo "Upgrading numpy" | tee -a $logFile
    runCmd $pipCmd install --upgrade numpy==2.3 # go back to numpy 2.3
    pip list | grep numpy                  # show the new version
  fi

  echo "Installing Local TTS ..."| tee -a $logFile
  echo | tee -a $logFile
  runCmd $pipCmd install piper-tts
  cd $baseDir/framework/services/tts/local
  if [ ! -d piper ]; then                  # not downloaded yet
    mkdir piper
    cd piper
    runCmd wget -q https://huggingface.co/rhasspy/piper-voices/resolve/v1.0.0/en/en_US/hfc_female/medium/en_US-hfc_female-medium.onnx
    runCmd wget -q https://huggingface.co/rhasspy/piper-voices/resolve/v1.0.0/en/en_US/hfc_female/medium/en_US-hfc_female-medium.onnx.json
    runCmd wget -q https://huggingface.co/rhasspy/piper-voices/resolve/v1.0.0/en/en_US/hfc_male/medium/en_US-hfc_male-medium.onnx
    runCmd wget -q https://huggingface.co/rhasspy/piper-voices/resolve/v1.0.0/en/en_US/hfc_male/medium/en_US-hfc_male-medium.onnx.json
    echo "Piper has been installed!" | piper --model en_US-hfc_male-medium.onnx --output_file testpiper.wav
    rc=$?
    if [ "$rc" != 0 ]; then
      echo "ERROR: piper test command returned $rc" | tee -a $logFile
      exit 4
    fi
    runCmd aplay testpiper.wav             # play audio file
  else                                     # assume it is installed
    echo "Skipping piper - already installed ..."| tee -a $logFile
  fi

  echo "Installing llama-cpp-python ..." | tee -a $logFile
  echo | tee -a $logFile
  if grep -qi "Jetson" /proc/device-tree/model 2>/dev/null || grep -qi "Orin" /proc/device-tree/model 2>/dev/null; then
    echo "Jetson Orin Nano detected. Installing with CUDA ..." | tee -a $logFile
    runCmd CUDACXX=/usr/local/cuda/bin/nvcc CMAKE_ARGS="-DGGML_CUDA=on" FORCE_CMAKE=1 $pipCmd install llama-cpp-python huggingface_hub
  else
    echo "Installing with OpenBLAS ..." | tee -a $logFile
    if command -v apt-get &>/dev/null; then
      runCmd sudo apt-get install -y libopenblas-dev
    fi
    runCmd CMAKE_ARGS="-DGGML_BLAS=ON -DGGML_BLAS_VENDOR=OpenBLAS" FORCE_CMAKE=1 $pipCmd install llama-cpp-python huggingface_hub
  fi

  echo "Pre-caching the LLM model from HuggingFace..." | tee -a $logFile
  local llmRepo=$(grep "LLMRepo:" "$configFile" | awk '{print $2}' | tr -d \''"')
  local llmFile=$(grep "LLMFile:" "$configFile" | awk '{print $2}' | tr -d \''"')

  if [ -n "$llmRepo" ] && [ -n "$llmFile" ]; then
    echo "Downloading model $llmRepo ($llmFile) ..." | tee -a $logFile
    runCmd $pythonCmd -c "from huggingface_hub import hf_hub_download; hf_hub_download(repo_id='$llmRepo', filename='$llmFile')"
  else
    echo "Warning: LLMRepo or LLMFile not found in config. Skipping pre-cache." | tee -a $logFile
  fi

  # Set whisper to run as a system daemon and log to /var/log/whisper.log
  runCmd sudo touch /var/log/whisper.log
  runCmd sudo chown $CURRENT_USER:$CURRENT_GROUP /var/log/whisper.log
  runCmd sudo chmod 664 /var/log/whisper.log
  if command -v systemctl &>/dev/null; then
    runCmd sudo systemctl enable whisper
  fi
  echo | tee -a $logFile

  echo "Copying Minimy scripts to /usr/local/sbin ..."| tee -a $logFile
  minimyScripts="startminimy stopminimy restartminimy grm cmpcode countminimy minimyver testhub.py testspoke.py"
  echo | tee -a $logFile
  echo "cd to $baseDir/install ..." | tee -a $logFile
  cd $baseDir/install
  runCmd sudo cp $minimyScripts /usr/local/sbin
  echo | tee -a $logFile
  echo "cd to /usr/local/sbin ..." | tee -a $logFile
  cd /usr/local/sbin
  runCmd sudo chown $CURRENT_USER:$CURRENT_GROUP $minimyScripts

  # Copy playlist file to local mpd playlists directory (in addition to installMpd)
  if [ -d "$baseDir/mpd/playlists" ]; then
    runCmd cp $baseDir/install/great_songs.m3u "$baseDir/mpd/playlists/"
  fi

  echo " "
  echo "Install Complete at `date`" | tee -a $logFile
 }                                         # buildVenv()

# global variables
baseDir="$HOME/minimy"
configFile="$baseDir/install/mmconfig.yml" # Minimy config file
hub=""                                     # hub server
let lastSecs=$SECONDS
timeSt=`date +"%y-%m-%d-%H-%M-%S"`
logFile="$HOME/$timeSt-installminimy.out"  # output file
if [ "$MINIMY_SAVELOGS" = "false" ]; then
  logFile="/dev/null"                      # if logging is disabled, log to /dev/null
fi
musicDir=""                                # directory with music files
let stepNum=0

# User info (will be set by detectUserInfo)
CURRENT_USER=""
CURRENT_UID=""
CURRENT_GROUP=""
LOGS_MOUNT_UNIT=""
TMP_MOUNT_UNIT=""

# main()
detectUserInfo                             # detect user information first
getPlatform                                # verify supported platform
checkEnv                                   # check the environment
generateConfigFile                         # generate config file from template
parseArgs $@                               # parse arguments
setMinimyVars                              # set config file variables
buildVenv                                  # do the work
let min=$SECONDS/60
let sec=$SECONDS%60
if [ $sec -lt 10 ]; then                   # add a leading 0
  sec="0$sec"
fi
echo "Successfully installed Minimy in $min:$sec" | tee -a $logFile
echo "Log file: $logFile"
