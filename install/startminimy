#!/bin/bash
#
# startminimy - start the minimy personal voice assistant and music player
#

# Detect base directory dynamically
if [ -n "$SVA_BASE_DIR" ]; then
  baseDir="$SVA_BASE_DIR"
else
  baseDir="$HOME/minimy"
fi
logDir="$baseDir/logs"

# Detect current user information
CURRENT_USER=$(whoami)

#+--------------------------------------------------------------------------+
function checkEnv
# Check the environment
#+--------------------------------------------------------------------------+
 {
  : SOURCE: ${BASH_SOURCE}
  : STACK:  ${FUNCNAME[@]}

  if [ ! -d $baseDir ]; then
    echo "ERROR: base directory $baseDir not found"
    echo "To clone Minimy to your home directory: "
    echo "cd; git clone https://github.com/mike99mac/minimy-mike99mac"
    exit 1
  fi
  if [ ! -d $logDir ]; then
    echo "WARNING: log directory $logDir not found, creating it..."
    mkdir -p $logDir
  fi
  ps -ef | grep "python3.*minimy" | grep -v grep | grep -v whisper
  if [ $? = 0 ]; then                      # minimy is running
    echo "It appears Minimy is already running!"
    exit 3
  fi
 }

#+--------------------------------------------------------------------------+
function umountTmpfs
# Unmount a temporary file system if it is mounted
# Arg 1: file system to umount
#+--------------------------------------------------------------------------+
 {
  : SOURCE: ${BASH_SOURCE}
  : STACK:  ${FUNCNAME[@]}

  fileSystem=$1
  echo "Unmounting tmpfs file system $fileSystem..."
  fsType=`mount | grep $fileSystem | awk '{print $1}'` # check if it's mounted
  if [ "$fsType" = "tmpfs" ]; then
    sudo umount $fileSystem
  fi
 }                                         # umountTmpfs()

#+--------------------------------------------------------------------------+
function mountTmpfs
# Mount a file system in a tmpfs using systemd .mount files
# Arg 1    : systemd .mount file to use
# Args 2-n : description of the file system
#+--------------------------------------------------------------------------+
 {
  : SOURCE: ${BASH_SOURCE}
  : STACK:  ${FUNCNAME[@]}

  local mountFile=$1
  shift
  local desc="$@"                          # remaining args are desription

  local mountDir=`echo $mountFile | sed 's:-:/:g'`
  local fsType=`mount | grep $mountDir | awk '{print $5}'`
  if [ "$fsType" = tmpfs ]; then           # already a tmpfs
    echo "$mountDir is already a tmpfs"
    return
  fi
  echo "making directory $fileSystem a tmpfs ..."
  cmd="sudo systemctl start $mountFile"
  eval $cmd
  rc=$?
  if [ "$rc" != 0 ]; then
    echo "WARNING $cmd returned $rc - proceeding without tmpfs $desc"
  else
    echo "$cmd was successful"
  fi
 }                                         # mountTmpfs()

#+--------------------------------------------------------------------------+
function getMountUnitName
# Generate the systemd mount unit name based on the base directory path
#+--------------------------------------------------------------------------+
 {
  : SOURCE: ${BASH_SOURCE}
  : STACK:  ${FUNCNAME[@]}

  # systemd mount units must be named after the mount path with - replacing /
  echo "$baseDir" | sed 's|^/||; s|/|-|g'
 }                                         # getMountUnitName()

#+--------------------------------------------------------------------------+
function mountUmountDirs
# make log files directories tmpfs's to prolong the life of the micro-SD card
#+--------------------------------------------------------------------------+
 {
  : SOURCE: ${BASH_SOURCE}
  : STACK:  ${FUNCNAME[@]}

  # Get the mount unit base name
  local mountUnitPath=$(getMountUnitName)

  # unmount and remount a tmpfs over $baseDir/logs
  umountTmpfs $baseDir/logs
  sleep 1
  mountTmpfs ${mountUnitPath}-logs.mount Minimy log directory

  # mount a tmpfs over $baseDir/tmp and create three subdirectories
  echo "Mounting tmpfs over $baseDir/tmp"
  umountTmpfs $baseDir/tmp
  mountTmpfs ${mountUnitPath}-tmp.mount Minimy temp directory
  sleep 1
  for nextDir in save_audio save_text save_tts; do
    if [ ! -d $baseDir/tmp/$nextDir ]; then
      echo "Making directory: $baseDir/tmp/$nextDir"
      mkdir -p $baseDir/tmp/$nextDir
    fi
  done
 }                                         # mountUmountDirs()

#+--------------------------------------------------------------------------+
function startSystem
# Start Minimy base components
#+--------------------------------------------------------------------------+
 {
  : SOURCE: ${BASH_SOURCE}
  : STACK:  ${FUNCNAME[@]}

  cd $baseDir

  # Use explicit path to venv python to ensure packages are available
  local venvPython="$baseDir/minimy_venv/bin/python3"

  if [ ! -f "$venvPython" ]; then
    echo "ERROR: Virtual environment python not found at $venvPython"
    exit 4
  fi

  export PYTHONPATH="$baseDir"
  export SVA_BASE_DIR="$baseDir"
  export GOOGLE_APPLICATION_CREDENTIALS="$baseDir/install/my-google-key.json"
  logDir="$baseDir/logs"

  echo "Starting system skills ..."
  cd $baseDir/skills/system_skills
  $venvPython skill_system.py >> $logDir/skills.log &
  sleep 1
  echo "Starting intent service ..."
  cd $baseDir
  $venvPython framework/services/intent/intent.py >> $logDir/intent.log &
  sleep 2
  echo "Starting media player ..."
  $venvPython framework/services/output/media_player.py >> $logDir/skills.log &
  echo "Starting TTS service ..."
  $venvPython framework/services/tts/tts.py >> $logDir/tts.log &
  echo "Starting STT service ..."
  $venvPython framework/services/stt/stt.py >> $logDir/stt.log &
  sleep 1
 }                                         # startSystem()

#+--------------------------------------------------------------------------+
function loadOneSkill
# load one skill from __init__.py
# Arg 1    : Skill directory
# Args 2-n : description of the skill
#+--------------------------------------------------------------------------+
 {
  : SOURCE: ${BASH_SOURCE}
  : STACK:  ${FUNCNAME[@]}

  local theDir=$1
  shift
  local desc="$@"

  if [ ! -d $theDir ]; then
    echo "ERROR: Directory $theDir not found"
    exit 5
  fi
  cd $theDir
  echo "Starting $desc from directory $theDir ..."
  $baseDir/minimy_venv/bin/python3 __init__.py $PWD &
 }                                         # loadOneSkill{}

#+--------------------------------------------------------------------------+
function loadSystemSkills
# load all system skills
#+--------------------------------------------------------------------------+
 {
  : SOURCE: ${BASH_SOURCE}
  : STACK:  ${FUNCNAME[@]}

  echo "Starting System Skills ..."
  cd $baseDir
  local venvPython="$baseDir/minimy_venv/bin/python3"
  $venvPython skills/system_skills/skill_fallback.py &
  $venvPython skills/system_skills/skill_media.py &
  $venvPython skills/system_skills/skill_volume.py &
  $venvPython skills/system_skills/skill_alarm.py &
  sleep 2
 }                                       # loadSystemSkills()

#+--------------------------------------------------------------------------+
function loadUserSkills
# load all user skills
#+--------------------------------------------------------------------------+
 {
  : SOURCE: ${BASH_SOURCE}
  : STACK:  ${FUNCNAME[@]}

  echo "Starting User Skills ..."
  # do not load these skills for now
  # cd $baseDir/skills/user_skills
  # loadOneSkill ../connectivity Connectivity skill
  # loadOneSkill ../ha_skill Home Assistant skill
  # loadOneSkill ../email Email skill
  # loadOneSkill ../example1 Example 1 skill
  # loadOneSkill ../npr_news NPR News skill
  # loadOneSkill ../rfm RFM skill
  # loadOneSkill ../wiki Wiki skill
  # loadOneSkill ../youtube YouTube skill
  loadOneSkill $baseDir/skills/user_skills/help Help skill
  loadOneSkill $baseDir/skills/user_skills/timedate TimeDate skill
  loadOneSkill $baseDir/skills/user_skills/weather Weather skill
  loadOneSkill $baseDir/skills/user_skills/mpc music and news skill
  sleep 3
 }                                         # loadUserSkills()

#+--------------------------------------------------------------------------+
function loadOtherServices
# load other processes
#+--------------------------------------------------------------------------+
 {
  : SOURCE: ${BASH_SOURCE}
  : STACK:  ${FUNCNAME[@]}

  cd $baseDir
  local venvPython="$baseDir/minimy_venv/bin/python3"
  echo "Starting buttons ..."
  $venvPython framework/services/input/buttons.py &
  echo "Starting the mic ..."
  $venvPython framework/services/input/mic.py &
 }                                       # loadOtherServices()

# main()
export SVA_BASE_DIR="$baseDir"

echo "Starting Minimy at `date` ..."
echo "User: $CURRENT_USER"
echo "Base directory: $baseDir"
checkEnv
mountUmountDirs                            # unmount then remount logs and tmp dirs as tmpfs's
startSystem
loadSystemSkills
loadUserSkills
loadOtherServices
echo "Started Minimy ..."
