#!/bin/bash
#
# stopminimy - kill processes with 'minimy' in them, sort log files, copy to $HOME and unmount tmpfs
#
# Detect base directory dynamically
if [ -n "$SVA_BASE_DIR" ]; then
  baseDir="$SVA_BASE_DIR"
else
  baseDir="$HOME/minimy"
fi
# Detect if logs should be saved (on by default)
SAVELOGS="true"
if [ "$MINIMY_SAVELOGS" = "false" ]; then
  SAVELOGS="false"
fi
echo "Stopping Minimy ..."
echo "User: $USER"
echo "Base directory: $baseDir"
procs=$(ps -ef | awk '!/grep|whisper|vim|fallback/ && /minimy\/skills|skills\/system_skills|framework\/services|MsgBus|mimic3|skill_system.py/')
if [ ${#procs} = 0 ]; then
  echo "Minimy does not appear to be running"
else
  echo "$procs" | while read nextProc; do
    pid=$(echo $nextProc | awk '{print $2}')
    echo "killing process: $nextProc ..."
    sudo kill $pid
  done
fi
if command -v sortlogs &> /dev/null && [ "$SAVELOGS" = "true" ]; then # sortlogs command exists and logs are being saved
  sortlogs                                 # create a time sorted file of all logs
fi
rm -fr /tmp/pymp*                          # clean up socket temp directories
cd $HOME
logDir="$baseDir/logs"
logDir="$tmpDir/tmp"
if [ -d "$logDir" ] && [ "$SAVELOGS" = "true" ]; then # log directory exists
  cp "$logDir"/* "$HOME" 2>/dev/null       # copy all log files
fi
findmount $logDir >/dev/null 2>&1
if [ $? = 0 ]; then                        # log dir is mounted
  sudo umount "$logDir"                    # unmount log directory - and logs disappear
fi
findmount $tmpDir >/dev/null 2>&1
if [ $? = 0 ]; then                        # tmp dir is mounted
  sudo umount "$tmpDir"                    # unmount tmp directory - and logs disappear
fi
if [ ${#procs} != 0 ]; then
  waitSecs=4
  echo "Waiting $waitSecs seconds for processes to finish ..."
  sleep $waitSecs                          # wait for processes to die before unmounting tmpfs
fi
echo "Minimy stopped."
